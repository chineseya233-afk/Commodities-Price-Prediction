# Python 字节码和测试缓存
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# 虚拟环境和本地工具状态
.venv/
.venv*/
venv/
env/
.superpowers/
.playwright-cli/
.playwright-mcp/

# 本地备份和历史快照
*backup*/
*_backup/
*.bak
*.old
*.tmp
archive/
archives/

# 密钥和本地环境配置
# 仓库跟踪的 .env 是公开配置模板。真实私有值请放在 .env.local、
# .env.private 等仅本地使用的文件中，或对本机 .env 改动设置 skip-worktree。
.env.*
!.env
*.pem
*.key
*.crt

# 本地数据库和运行状态
*.db
*.sqlite
*.sqlite3
data/*.db
data/*.sqlite*
data/temp/

# 日志、生成输出和训练临时文件
*.log
output/
lightning_logs/
**/lightning_logs/
runs/
wandb/

# 前端依赖和构建产物
node_modules/
dist/
build/
.vite/

# 操作系统和编辑器文件
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# 保留本 POC 所需的轻量模型产物。
!backend/ml/trained_models/
!backend/ml/trained_models/**
