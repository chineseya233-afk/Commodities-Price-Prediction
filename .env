# Public setup template for CommodityPricePrediction.
# Replace placeholder values on your own computer before running in production.
# Do not commit real API keys, production passwords, private database URLs, or customer data.

# Application
APP_NAME=CommodityPricePrediction
APP_ENV=development
DEBUG=true

# Database
# Local default: SQLite file under ./data.
# Production: replace with your SQLAlchemy database URL, for example PostgreSQL or MySQL.
DATABASE_URL=sqlite+aiosqlite:///./data/commodity_prediction.db

# Sessions / auth
# JWT_SECRET_KEY is not obtained from an API provider. Generate it locally:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Paste the generated value below before using the app outside local testing.
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
SESSION_IDLE_MINUTES=30
REMEMBER_ME_DAYS=14
SESSION_COOKIE_NAME=commodity_session
# Local HTTP: false. Public HTTPS deployment: true.
COOKIE_SECURE=false

# POC demo users. Change these before sharing beyond local testing.
ADMIN_DEFAULT_PASSWORD=Admin123456@
EXECUTIVE_DEFAULT_PASSWORD=Exec123456@
PROCUREMENT_DEFAULT_PASSWORD=Proc123456@

# Generic OpenAI-compatible LLM.
# DeepSeek key: https://platform.deepseek.com/api_keys
# OpenAI key: https://platform.openai.com/api-keys
# Other providers: use their OpenAI-compatible API key, base URL, and model name.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
OPENAI_COMPATIBLE_MODEL=deepseek-v4-pro
OPENAI_COMPATIBLE_PROVIDER=deepseek

# Backward-compatible aliases are still supported, but new setups should prefer
# OPENAI_COMPATIBLE_API_KEY / OPENAI_COMPATIBLE_BASE_URL / OPENAI_COMPATIBLE_MODEL.
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# Market data APIs
# EIA key registration: https://www.eia.gov/opendata/register.php
# The demo key is limited and should be replaced for stable real-data use.
EIA_API_KEY=demo
EIA_BASE_URL=https://api.eia.gov/v2
EIA_DIESEL_SERIES=EER_EPD2DXL0_PF4_Y35NY_DPG

# FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html
# Requires a FRED account. Leave blank to run with reduced macro-data coverage.
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred

# Model
MODEL_DIR=backend/ml/trained_models
TRAINED_MODELS_DIR=backend/ml/trained_models
PREDICTION_HORIZON=30
LOOKBACK_WINDOW=30
DATA_REFRESH_SECONDS=300
MARKET_DATA_START_DATE=2006-06-01
TEMP_DIR=data/temp

# Server
BACKEND_PORT=8000
FRONTEND_PORT=3000
