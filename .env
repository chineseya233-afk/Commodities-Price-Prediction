# 大宗商品价格预测系统公开配置模板。
# 使用前请在自己的电脑上替换占位值。
# 不要把真实 API key、生产密码、私有数据库地址或客户数据提交到 GitHub。

# 应用配置
APP_NAME=CommodityPricePrediction
APP_ENV=development
DEBUG=true

# 数据库
# 本地默认使用 ./data 下的 SQLite 文件。
# 生产环境可以替换为 PostgreSQL 或 MySQL 等 SQLAlchemy 数据库地址。
DATABASE_URL=sqlite+aiosqlite:///./data/commodity_prediction.db

# 会话和认证
# JWT_SECRET_KEY 不需要从第三方平台获取，请在本地生成：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 非本地测试场景请把生成结果填到下面。
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
SESSION_IDLE_MINUTES=30
REMEMBER_ME_DAYS=14
SESSION_COOKIE_NAME=commodity_session
# 本地 HTTP 使用 false；公网 HTTPS 部署必须改为 true。
COOKIE_SECURE=false

# POC 演示用户。共享或部署前请修改这些默认密码。
ADMIN_DEFAULT_PASSWORD=Admin123456@
EXECUTIVE_DEFAULT_PASSWORD=Exec123456@
PROCUREMENT_DEFAULT_PASSWORD=Proc123456@

# 通用 OpenAI-compatible LLM 配置。
# DeepSeek key 获取地址：https://platform.deepseek.com/api_keys
# OpenAI key 获取地址：https://platform.openai.com/api-keys
# 其他供应商请填写其 OpenAI-compatible API key、base URL 和模型名。
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
OPENAI_COMPATIBLE_MODEL=deepseek-v4-pro
OPENAI_COMPATIBLE_PROVIDER=deepseek

# 旧版兼容变量仍然支持，但新配置建议优先使用：
# OPENAI_COMPATIBLE_API_KEY / OPENAI_COMPATIBLE_BASE_URL / OPENAI_COMPATIBLE_MODEL。
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 市场数据 API
# EIA key 注册地址：https://www.eia.gov/opendata/register.php
# demo key 只能用于有限测试，稳定使用真实数据时建议替换为自己的 key。
EIA_API_KEY=demo
EIA_BASE_URL=https://api.eia.gov/v2
EIA_DIESEL_SERIES=EER_EPD2DXL0_PF4_Y35NY_DPG

# FRED API key 获取说明：https://fred.stlouisfed.org/docs/api/api_key.html
# 需要登录 FRED 账号申请或查看。不填写时，系统会以较少宏观数据运行。
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred

# 模型配置
MODEL_DIR=backend/ml/trained_models
TRAINED_MODELS_DIR=backend/ml/trained_models
PREDICTION_HORIZON=30
LOOKBACK_WINDOW=30
DATA_REFRESH_SECONDS=300
MARKET_DATA_START_DATE=2006-06-01
TEMP_DIR=data/temp

# 服务端口
# 当前前端由 FastAPI 同端口托管，浏览器打开 http://127.0.0.1:8000 即可。
BACKEND_PORT=8000
